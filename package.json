{
  "name": "live-pose-tester",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "check:rig-registry": "node scripts/check-rig-registry.mjs",
    "check:motion-api": "node scripts/smoke-motion-api.mjs",
    "backend": "node backend/server.js",
    "backend:setup": "bash scripts/setup-motion-backend.sh",
    "dev:full": "npm run backend & npm run dev",
    "start:full": "npm run build && npm run backend & npm run preview",
    "preview": "vite preview --host 0.0.0.0 --port 5180",
    "start": "npm run build && npm run preview",
    "autostart:install": "bash scripts/install-autostart.sh install",
    "autostart:uninstall": "bash scripts/install-autostart.sh uninstall",
    "autostart:status": "bash scripts/install-autostart.sh status",
    "autostart:restart": "bash scripts/install-autostart.sh restart"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.0.3",
    "@mediapipe/drawing_utils": "^0.3.1675466124",
    "@mediapipe/holistic": "^0.5.1675471629",
    "better-sqlite3": "^12.4.1",
    "fastify": "^5.2.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "vite": "^7.3.5"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
