{
  "name": "live-pose-tester",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "models:scan": "node scripts/scan-body-models.js",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 5180",
    "start": "npm run build && npm run preview",
    "autostart:install": "bash scripts/install-autostart.sh install",
    "autostart:uninstall": "bash scripts/install-autostart.sh uninstall",
    "autostart:status": "bash scripts/install-autostart.sh status",
    "autostart:restart": "bash scripts/install-autostart.sh restart"
  },
  "dependencies": {
    "@mediapipe/drawing_utils": "^0.3.1675466124",
    "@mediapipe/holistic": "^0.5.1675471629",
    "kalidokit": "^1.1.5",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "vite": "^7.3.5"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
